# ─── Midnight network ────────────────────────────────────────────────────────
# Local (Docker):  undeployed
# Testnet:         preprod
MIDNIGHT_NETWORK_ID=preprod
# NEXT_PUBLIC_ prefix makes this available in the browser (for Lace wallet connect)
NEXT_PUBLIC_MIDNIGHT_NETWORK_ID=preprod

# Testnet public endpoints (use for Netlify / production)
MIDNIGHT_INDEXER_URL=https://indexer.testnet-02.midnight.network/api/v1/graphql
MIDNIGHT_RPC_URL=wss://rpc.testnet-02.midnight.network
MIDNIGHT_PROOF_SERVER_URL=https://proof-server.testnet-02.midnight.network

# Local Docker endpoints (use these when MIDNIGHT_NETWORK_ID=undeployed)
# MIDNIGHT_INDEXER_URL=http://127.0.0.1:8088/api/v4/graphql
# MIDNIGHT_RPC_URL=ws://127.0.0.1:9944
# MIDNIGHT_PROOF_SERVER_URL=http://127.0.0.1:6300

# ─── Deployed contract addresses ─────────────────────────────────────────────
# Run `pnpm --filter contract run deploy` to get these after deploying.
LENDING_POOL_ADDRESS=
GOVERNANCE_ADDRESS=
CREDIT_PROOF_ADDRESS=
ASSET_PROOF_ADDRESS=

# ─── AI document parsing ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-

# ─── Open banking (optional) ─────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
OPEN_BANKING_CLIENT_ID=
OPEN_BANKING_CLIENT_SECRET=
NEXT_PUBLIC_OPEN_BANKING_CLIENT_ID=
