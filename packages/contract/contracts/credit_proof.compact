pragma language_version >= 0.16 && <= 0.23;

import CompactStandardLibrary;

export struct CreditWeights {
  income:      Uint<8>,
  debt:        Uint<8>,
  payments:    Uint<8>,
  cashflow:    Uint<8>,
  utilisation: Uint<8>,
  assets:      Uint<8>,
}

// Public proof outputs — keyed by borrower's derived public key
export ledger grades:        Map<Bytes<32>, Uint<8>>;
export ledger eligibility:   Map<Bytes<32>, Boolean>;
export ledger score_hashes:  Map<Bytes<32>, Bytes<32>>;
export ledger attestations:  Map<Bytes<32>, Boolean>;

// Weights are managed by governance contract; initialised at deploy
export ledger credit_weights: CreditWeights;

// Deployer provides initial weights at deploy time
witness initial_income():      Uint<8>;
witness initial_debt():        Uint<8>;
witness initial_payments():    Uint<8>;
witness initial_cashflow():    Uint<8>;
witness initial_utilisation(): Uint<8>;
witness initial_assets():      Uint<8>;

// Private inputs — normalised by Claude off-chain, never leave the prover
witness local_secret_key():      Bytes<32>;
witness get_income_score():      Uint<64>;
witness get_debt_score():        Uint<64>;
witness get_payments_score():    Uint<64>;
witness get_cashflow_score():    Uint<64>;
witness get_utilisation_score(): Uint<64>;
witness get_assets_score():      Uint<64>;

constructor() {
  credit_weights = CreditWeights {
    income:      disclose(initial_income()),
    debt:        disclose(initial_debt()),
    payments:    disclose(initial_payments()),
    cashflow:    disclose(initial_cashflow()),
    utilisation: disclose(initial_utilisation()),
    assets:      disclose(initial_assets()),
  };
}

pure circuit derive_pk(sk: Bytes<32>): Bytes<32> {
  return persistentHash<Vector<2, Bytes<32>>>([pad(32, "midvault:pk:"), sk]);
}

// Thresholds scaled ×100 to avoid on-chain division:
//   score >= 80  →  weighted_sum >= 8000  →  grade 1 (A)
//   score >= 60  →  weighted_sum >= 6000  →  grade 2 (B)
//   score >= 40  →  weighted_sum >= 4000  →  grade 3 (C)
//   else         →  grade 0 (rejected)
pure circuit assign_grade(weighted: Uint<64>): Uint<8> {
  if (weighted >= 8000) { return 1 as Uint<8>; }
  if (weighted >= 6000) { return 2 as Uint<8>; }
  if (weighted >= 4000) { return 3 as Uint<8>; }
  return 0 as Uint<8>;
}

export circuit prove_credit(attested: Boolean): [] {
  const sk       = local_secret_key();
  const borrower = derive_pk(sk);

  const income      = get_income_score();
  const debt        = get_debt_score();
  const payments    = get_payments_score();
  const cashflow    = get_cashflow_score();
  const utilisation = get_utilisation_score();
  const assets      = get_assets_score();

  assert(disclose(income      <= 100), "income out of range");
  assert(disclose(debt        <= 100), "debt out of range");
  assert(disclose(payments    <= 100), "payments out of range");
  assert(disclose(cashflow    <= 100), "cashflow out of range");
  assert(disclose(utilisation <= 100), "utilisation out of range");
  assert(disclose(assets      <= 100), "assets out of range");

  const w  = credit_weights;
  const t1 = (income      * (w.income      as Uint<64>)) as Uint<64>;
  const t2 = (debt        * (w.debt        as Uint<64>)) as Uint<64>;
  const t3 = (payments    * (w.payments    as Uint<64>)) as Uint<64>;
  const t4 = (cashflow    * (w.cashflow    as Uint<64>)) as Uint<64>;
  const t5 = (utilisation * (w.utilisation as Uint<64>)) as Uint<64>;
  const t6 = (assets      * (w.assets      as Uint<64>)) as Uint<64>;

  const s12      = (t1 + t2) as Uint<64>;
  const s34      = (t3 + t4) as Uint<64>;
  const s56      = (t5 + t6) as Uint<64>;
  const s1234    = (s12 + s34) as Uint<64>;
  const weighted = (s1234 + s56) as Uint<64>;

  const g    = assign_grade(weighted);
  const hash = persistentHash<Vector<6, Uint<64>>>([
    income, debt, payments, cashflow, utilisation, assets,
  ]);

  const b = disclose(borrower);
  grades.insert(b, disclose(g));
  eligibility.insert(b, disclose(g != 0));
  score_hashes.insert(b, disclose(hash));
  attestations.insert(b, disclose(attested));
}
